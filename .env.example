# 데이터베이스 (SQLite 파일)
DATABASE_URI=file:./jinsung.db
# Payload 암호화 시크릿 (배포 시 openssl rand -hex 32 로 생성)
PAYLOAD_SECRET=YOUR_SECRET_HERE
# 첫 실행 시 자동 생성되는 고정 관리자 계정
PAYLOAD_ADMIN_EMAIL=admin@example.com
PAYLOAD_ADMIN_PASSWORD=change-this-password
# 사이트 절대 URL (메타데이터/OG용)
SITE_URL=http://localhost:3000

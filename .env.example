# ── 로컬 개발용 ──────────────────────────────
# 데이터베이스 (SQLite 파일). 도커 배포 시 compose가 file:./data/jinsung.db 로 덮어씀
DATABASE_URI=file:./jinsung.db
# Payload 암호화 시크릿 (배포 시 반드시 새로 생성: openssl rand -hex 32)
PAYLOAD_SECRET=YOUR_SECRET_HERE
# 첫 실행 시 자동 생성되는 고정 관리자 계정
PAYLOAD_ADMIN_EMAIL=admin@example.com
PAYLOAD_ADMIN_PASSWORD=change-this-password
# 사이트 절대 URL (메타데이터/OG용). 배포 시 https://도메인
SITE_URL=http://localhost:3000
# 카카오맵 JavaScript 앱키 (Kakao Developers 무료 발급). 없으면 지도는 폴백 표시
NEXT_PUBLIC_KAKAO_MAP_KEY=

# ── 배포(도커 compose)용 ─────────────────────
# 실제 도메인 (예: jinsung-laser.co.kr). 미설정 시 localhost
DOMAIN=localhost
# Let's Encrypt 인증서 발급 알림 이메일
ACME_EMAIL=admin@example.com
